generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  HOST
  ADMIN
}

enum BookingStatus {
  PENDING // щойно створено, без оплати
  HOLD // дати заблоковані на 15 хв під час оплати
  CONFIRMED // оплата пройшла / готівка підтверджена
  CANCELLED
  COMPLETED // клієнт виїхав — можна залишати відгук
}

enum PaymentMethod {
  ONLINE
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum CancellationPolicy {
  FLEXIBLE // безкоштовно за 48 год до заїзду
  STRICT // безкоштовно лише 24 год після бронювання (якщо до заїзду >7 днів)
}

enum BookingMode {
  INSTANT // автоматичне підтвердження
  REQUEST // власник має підтвердити вручну
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String?
  email String? @unique
  phone String? @unique
  image String?
  role  Role    @default(CLIENT)

  // ← НОВЕ ПОЛЕ
  passwordHash String? // bcrypt hash для Credentials, null для OAuth

  // Telegram / Viber для сповіщень
  telegramChatId String?
  viberUserId    String?

  // Auth (next-auth)
  accounts Account[]
  sessions Session[]

  // Зв'язки
  properties Property[]
  bookings   Booking[]
  reviews    Review[]

  @@map("users")
}

// ─── NextAuth ────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Property (База відпочинку) ───────────────────────────────────────────────
// Відповідає одному slug: zatyshok.com/p/verholy

model Property {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug        String  @unique // "verholy", "nasha-dacha"
  name        String
  description String?
  coverImage  String? // URL з Cloudinary
  logoImage   String? // URL з Cloudinary

  // Локація
  address   String?
  city      String?
  region    String?
  latitude  Float?
  longitude Float?

  // Налаштування бізнес-логіки
  cancellationPolicy CancellationPolicy @default(FLEXIBLE)
  bookingMode        BookingMode        @default(INSTANT)

  // Підписка SaaS
  isActive        Boolean   @default(false) // активована підписка
  subscriptionEnd DateTime?

  // Рейтинг (денормалізовано для швидкого пошуку)
  ratingAvg   Float   @default(0)
  ratingCount Int     @default(0)
  isHidden    Boolean @default(false) // автоматично приховується якщо рейтинг < 3.0

  // Зв'язки
  hostId  String
  host    User     @relation(fields: [hostId], references: [id])
  units   Unit[]
  reviews Review[]

  // Додаткові теги/послуги на рівні всієї бази
  amenities PropertyAmenity[]

  @@map("properties")
}

// ─── PropertyAmenity (Послуги бази) ──────────────────────────────────────────
// Бейджі: WiFi, чан, риболовля, мангал тощо

model PropertyAmenity {
  id    String @id @default(cuid())
  icon  String // назва іконки lucide: "wifi", "flame", "fish"
  label String // "Wi-Fi", "Чан", "Риболовля"

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_amenities")
}

// ─── Unit (Одиниця оренди) ────────────────────────────────────────────────────
// Конкретна альтанка, будиночок, глемпінг всередині бази

model Unit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String // "Альтанка біля води №1", "A-Frame з чаном"
  description   String?
  pricePerNight Decimal // ціна за ніч / день

  // Тип об'єкта для фільтрації
  type UnitType

  // Максимальна кількість гостей
  maxGuests Int @default(2)

  // Зображення (масив URL з Cloudinary)
  images UnitImage[]

  // Зв'язки
  propertyId   String
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  blockedDates BlockedDate[]
  amenities    UnitAmenity[]

  @@map("units")
}

enum UnitType {
  HOUSE // будинок
  GLAMPING // глемпінг
  GAZEBO // альтанка
  AFRAME // A-Frame
  TENT // намет
  OTHER
}

model UnitImage {
  id     String @id @default(cuid())
  url    String // Cloudinary URL
  order  Int    @default(0) // для drag & drop сортування
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("unit_images")
}

model UnitAmenity {
  id    String @id @default(cuid())
  icon  String
  label String

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("unit_amenities")
}

// ─── BlockedDate ──────────────────────────────────────────────────────────────
// Ручне закриття дат власником (дзвінок по телефону тощо)

model BlockedDate {
  id     String   @id @default(cuid())
  date   DateTime @db.Date
  reason String? // "Власне використання", "Технічні роботи"

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, date])
  @@map("blocked_dates")
}

// ─── Booking ──────────────────────────────────────────────────────────────────

model Booking {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkIn  DateTime @db.Date
  checkOut DateTime @db.Date

  status BookingStatus @default(PENDING)

  // Гостьові дані (заповнюються при checkout без авторизації)
  guestName    String?
  guestPhone   String?
  guestComment String?

  // Фінанси
  totalAmount   Decimal
  prepaidAmount Decimal        @default(0) // передоплата
  paymentMethod PaymentMethod?

  // HOLD: до якого часу заблоковано
  holdExpiresAt DateTime?

  // Зв'язки
  userId String? // null якщо гість без акаунту
  user   User?   @relation(fields: [userId], references: [id])
  unitId String
  unit   Unit    @relation(fields: [unitId], references: [id])

  transaction Transaction?
  review      Review?

  @@map("bookings")
}

// ─── Transaction ─────────────────────────────────────────────────────────────

model Transaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  amount Decimal
  method PaymentMethod
  status PaymentStatus @default(PENDING)

  // ID транзакції від платіжної системи (WayForPay, Mono тощо)
  externalId String?
  // URL для повернення коштів
  refundId   String?

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  @@map("transactions")
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  rating  Int // 1-5
  comment String?

  // Захист: тільки COMPLETED бронювання
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  @@map("reviews")
}
